{
  "name": "ubrush-core-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "HTTPS=1 HOST=0.0.0.0 webpack serve --mode development",
    "dev:lan": "webpack serve --mode development --host 0.0.0.0",
    "dev:https": "HTTPS=1 HOST=0.0.0.0 webpack serve --mode development",
    "cert:dev": "node scripts/create-dev-cert.js",
    "build": "webpack --mode production",
    "deploy": "npm run build && gh-pages -d dist --repo git@github-alvitavo:alvitavo/ubrush-demo.git",
    "deploy:webgpu": "npm run build && gh-pages -d dist --dest webgpu --add --repo git@github-alvitavo:alvitavo/ubrush-demo.git"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "copy-webpack-plugin": "^11.0.0",
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "dependencies": {
    "base64-arraybuffer": "^0.2.0",
    "upng-js": "^2.1.0"
  }
}
